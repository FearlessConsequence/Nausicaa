<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:CourseWork.Models"
        x:Class="CourseWork.Views.DraftsWindow"
        Title="Черновики"
        xmlns:controls="using:CourseWork.Controls"
        WindowState="Maximized">

    <Window.Resources>
        <DataTemplate x:Key="DraftCardTemplate" DataType="models:Draft">
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="10">
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <Border Background="#0F4B5E" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="{Binding TypeDisplayName}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="{Binding DateFormatted}" FontSize="12" Foreground="#6C757D" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="✏️" Tag="{Binding Id}" Click="BtnEdit_Click" Width="30" Height="30" Background="#28A745" Foreground="White" BorderThickness="0" CornerRadius="4"/>
                        <Button Content="🗑️" Tag="{Binding Id}" Click="BtnDelete_Click" Width="30" Height="30" Background="#DC3545" Foreground="White" BorderThickness="0" CornerRadius="4"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                               Text="{Binding PersonName}" 
                               FontSize="12" 
                               Foreground="#0F4B5E"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid RowDefinitions="*" ColumnDefinitions="200, *">
        <controls:LeftPanel x:Name="LeftPanelControl" 
                    Grid.Column="0" 
                    Grid.Row="0" 
                    Grid.RowSpan="2"/>

        <Border Grid.Column="1" Background="#F8F9FA" Padding="30">
            <StackPanel Spacing="20">
                <TextBlock Text="Черновики" FontSize="24" FontWeight="Bold" Foreground="#0F4B5E"/>
                <TextBlock x:Name="txt_draftsCount" FontSize="14" Foreground="#6C757D"/>
                <ComboBox x:Name="cmb_filterType" Width="200" SelectionChanged="CmbFilter_SelectionChanged">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="Обращение"/>
                    <ComboBoxItem Content="Заявление"/>
                    <ComboBoxItem Content="Адм. протокол"/>
                    <ComboBoxItem Content="Протокол объяснения"/>
                    <ComboBoxItem Content="Направление на мед. освид."/>
                </ComboBox>
                <ScrollViewer MaxHeight="500">
                    <ItemsControl x:Name="draftsList" 
                    ItemTemplate="{StaticResource DraftCardTemplate}"/>
                </ScrollViewer>
                <TextBlock x:Name="txt_empty" Text="Нет черновиков" IsVisible="False" HorizontalAlignment="Center" Foreground="#999"/>
            </StackPanel>
        </Border>
        <controls:NotificationsControl x:Name="NotificationsControl" 
                               Grid.Column="0" 
                               Grid.ColumnSpan="2"
                               Grid.Row="1"      
                               VerticalAlignment="Bottom"/>
    </Grid>
</Window>