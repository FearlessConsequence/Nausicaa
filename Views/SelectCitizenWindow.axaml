<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CourseWork.Views.SelectCitizenWindow"
        Title="Выбор гражданина"
        Width="900" 
        Height="700"
        xmlns:controls="using:CourseWork.Controls"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        WindowState="Maximized">

    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="16"
                BoxShadow="0 4 12 #1000000A">
            
            <Grid RowDefinitions="Auto, Auto, Auto, *">
                
                <StackPanel Grid.Row="0" Margin="24,24,24,16" Spacing="8">
                    <TextBlock Text="Выбор гражданина" FontSize="24" FontWeight="SemiBold" Foreground="#1E2A3A"/>
                    <TextBlock Text="Заполните поля для поиска гражданина" FontSize="13" Foreground="#6C757D"/>
                </StackPanel>
                
                <Border Grid.Row="1" Margin="24,0,24,16" Background="#F8F9FA" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="12">
                        
                        <Grid ColumnDefinitions="1.2*, 1*, 1*" ColumnSpacing="10">
                          <StackPanel Grid.Column="0" Spacing="4">
                              <TextBlock Text="Фамилия" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                              <TextBox x:Name="txt_last_name" Height="36" Watermark="Иванов" FontSize="13"/>
                              <TextBlock x:Name="txt_last_name_error" 
                                        Text="Введите фамилию" 
                                        FontSize="10" 
                                        Foreground="#DC3545"
                                        IsVisible="False"/>
                          </StackPanel>
                          
                          <StackPanel Grid.Column="1" Spacing="4">
                              <TextBlock Text="Имя" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                              <TextBox x:Name="txt_first_name" Height="36" Watermark="Иван" FontSize="13"/>
                              <TextBlock x:Name="txt_first_name_error" 
                                        Text="Введите имя" 
                                        FontSize="10" 
                                        Foreground="#DC3545"
                                        IsVisible="False"/>
                          </StackPanel>
                          
                          <StackPanel Grid.Column="2" Spacing="4">
                              <TextBlock Text="Отчество" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                              <TextBox x:Name="txt_patronymic" Height="36" Watermark="Иванович" FontSize="13"/>
                              <TextBlock x:Name="txt_patronymic_error" 
                                        Text="Введите отчество" 
                                        FontSize="10" 
                                        Foreground="#DC3545"
                                        IsVisible="False"/>
                          </StackPanel>
                      </Grid>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Дата рождения" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <DatePicker x:Name="dp_birthday" Height="36" FontSize="13" CornerRadius="6" Width="200" HorizontalAlignment="Left"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Адрес проживания" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <TextBox x:Name="txt_address" Height="36" Watermark="г. Москва, ул. Пушкина, д. 32" FontSize="13" Margin="10,0,0,10"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Телефон" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <TextBox x:Name="txt_phone" Height="36" Watermark="+7 999 123-45-67" FontSize="13" Margin="0,0,0,10"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Паспортные данные" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <TextBox x:Name="txt_passport" Height="36" Watermark="Серия 1234 Номер 567890" FontSize="13" Margin="0,0,0,20"/>
                        </StackPanel>
                        
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                          <Button Content="Найти" 
                                  Height="40" 
                                  Width="90"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  Background="#0F4B5E" 
                                  Foreground="White" 
                                  FontSize="14" 
                                  CornerRadius="8" 
                                  x:Name="btn_search"/>
                          
                          <Button Grid.Column="1" 
                                  Content="← Назад" 
                                  Height="40" 
                                  Width="120"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  Background="#6C757D" 
                                  Foreground="White" 
                                  FontSize="14" 
                                  CornerRadius="8" 
                                  x:Name="btn_cancel" Margin="10,0,0,0"/>
                      </Grid>
                    </StackPanel>
                </Border>
                
                <TextBlock Grid.Row="2" Margin="24,8,24,8" Text="Результаты поиска:" FontSize="14" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                
                <ScrollViewer Grid.Row="3" Margin="24,0,24,24" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="citizensContainer">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        CornerRadius="12"
                                        BorderBrush="#E9ECEF"
                                        BorderThickness="1"
                                        Padding="16,14"
                                        Margin="0,0,0,12"
                                        Cursor="Hand">
                                    
                                    <Grid ColumnDefinitions="*, Auto">
                                        
                                        <StackPanel Grid.Column="0" Spacing="8">
                                            
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding LastName}" FontSize="16" FontWeight="SemiBold" Foreground="#1E2A3A"/>
                                                <TextBlock Text="{Binding FirstName}" FontSize="16" FontWeight="SemiBold" Foreground="#1E2A3A"/>
                                                <TextBlock Text="{Binding Patronymic}" FontSize="16" FontWeight="SemiBold" Foreground="#1E2A3A"
                                                           IsVisible="{Binding Patronymic, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            </StackPanel>
                                            
                                            <StackPanel Orientation="Horizontal" Spacing="15">
                                                <TextBlock Text="{Binding Birthday, StringFormat='dd.MM.yyyy'}" FontSize="12" Foreground="#6C757D"/>
                                                <TextBlock Text="{Binding Phone}" FontSize="12" Foreground="#6C757D"
                                                           IsVisible="{Binding Phone, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            </StackPanel>
                                            
                                            <TextBlock Text="{Binding Address}" FontSize="12" Foreground="#495057" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1"
                                                Content="Выбрать →"
                                                Background="#0F4B5E"
                                                Foreground="White"
                                                CornerRadius="8"
                                                Padding="20,10"
                                                FontSize="13"
                                                Tag="{Binding}"
                                                VerticalAlignment="Center"
                                                Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <Border Grid.Row="3"
                        Background="White"
                        IsVisible="False"
                        x:Name="emptyStateBorder"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Spacing="16">
                        <TextBlock Text="👥" FontSize="64"/>
                        <TextBlock Text="Граждане не найдены" FontSize="18" Foreground="#6C757D"/>
                        <TextBlock Text="Измените параметры поиска" FontSize="14" Foreground="#ADB5BD"/>
                    </StackPanel>
                </Border>
                
            </Grid>
        </Border>
    </Grid>
</Window>