<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CourseWork.Views.ReferenceBooksWindow"
        Title="Справочники"
        WindowState="Maximized"
        xmlns:controls="using:CourseWork.Controls"
        Background="#F5F7FA">

    <Grid RowDefinitions="*" ColumnDefinitions="200, *">
        
        <controls:LeftPanel x:Name="LeftPanelControl" 
                        Grid.Column="0" 
                        Grid.Row="0" 
                        Grid.RowSpan="2"/>

        <Border Grid.Column="1" Grid.Row="0" Background="#F8F9FA" Padding="30">
            
            <Grid RowDefinitions="Auto, Auto, *">
                
    
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="Справочники" 
                               FontSize="28" 
                               FontWeight="SemiBold"
                               Foreground="#1E2A3A"/>
                    <TextBlock Text="Поиск информации в справочниках" 
                               FontSize="14" 
                               Foreground="#6C757D"
                               Margin="0,5,0,0"/>
                </StackPanel>
                
    
                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#E9ECEF"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,24">
                    
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
            
                        <ComboBox x:Name="cmb_search_type" 
                                  Height="42" 
                                  Width="160"
                                  FontSize="13"
                                  CornerRadius="6"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Статьи КоАП"/>
                            <ComboBoxItem Content="Должности"/>
                            <ComboBoxItem Content="Организации"/>
                        </ComboBox>
                        
            
                        <TextBox x:Name="txt_search" 
                                 Grid.Column="1"
                                 Height="42" 
                                 Watermark="Введите поисковый запрос..."
                                 FontSize="13"
                                 BorderBrush="#E0E0E0"
                                 CornerRadius="6"/>
                        
            
                        <Button Content="Найти" 
                                Grid.Column="2"
                                Height="39" 
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="80"
                                Background="#0F4B5E" 
                                Foreground="White"
                                FontSize="13"
                                CornerRadius="6"
                                x:Name="btn_search"/>
                    </Grid>
                </Border>
                
    
                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#E9ECEF"
                        BorderThickness="1"
                        Padding="20">
                    
                    <Grid RowDefinitions="Auto, *">
                        <TextBlock x:Name="txt_current_title" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Foreground="#0F4B5E"
                                   Margin="0,0,0,16"/>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="itemsContainer">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E9ECEF" 
                                                BorderThickness="0,0,0,1" 
                                                Padding="12,10"
                                                Margin="0,0,0,4">
                                            <ContentControl Content="{Binding}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        
                        <TextBlock x:Name="txt_empty" 
                                   Grid.Row="1"
                                   Text="Выберите тип справочника и введите поисковый запрос"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#6C757D"
                                   FontSize="14"
                                   IsVisible="True"/>
                    </Grid>
                </Border>
                
            </Grid>
        </Border>
        <controls:NotificationsControl x:Name="NotificationsControl" 
                               Grid.Column="0" 
                               Grid.ColumnSpan="2"
                               Grid.Row="1"      
                               VerticalAlignment="Bottom"/>
    </Grid>
</Window>