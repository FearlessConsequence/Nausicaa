<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CourseWork.Views.SelectDealWindow"
        Title="Выбор дела"
        Width="800" 
        Height="600"
        xmlns:controls="using:CourseWork.Controls"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        WindowState="Maximized">

    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="16"
                BoxShadow="0 4 12 #1000000A">
            
            <Grid RowDefinitions="Auto, Auto, Auto, *">
                
                <StackPanel Grid.Row="0" Margin="24,24,24,16" Spacing="8">
                    <TextBlock Text="Выбор дела" FontSize="24" FontWeight="SemiBold" Foreground="#1E2A3A"/>
                    <TextBlock Text="Заполните поля для поиска дела" FontSize="13" Foreground="#6C757D"/>
                </StackPanel>
                
                <Border Grid.Row="1" Margin="24,0,24,16" Background="#F8F9FA" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="12">
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="ФИО" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <TextBox x:Name="txt_fullname" Height="36" Watermark="Иванов Иван Иванович" FontSize="13"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Дата рождения" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <DatePicker x:Name="dp_birthday" Height="36" FontSize="13" CornerRadius="6"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Место проживания" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <TextBox x:Name="txt_address" Height="36" Watermark="г. Москва, ул. Пушкина, д. 32" FontSize="13"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Паспортные данные" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <TextBox x:Name="txt_passport" Height="36" Watermark="Серия 1234 Номер 567890" FontSize="13"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Телефон" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <TextBox x:Name="txt_phone" Height="36" Watermark="+7 999 123-45-67" FontSize="13"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Номер дела" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                            <TextBox x:Name="txt_deal_number" Height="36" Watermark="1001" FontSize="13"/>
                        </StackPanel>
                        
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Дата дела (от)" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                                <DatePicker x:Name="dp_date_from" Height="36" FontSize="13" CornerRadius="6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Дата дела (до)" FontSize="12" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                                <DatePicker x:Name="dp_date_to" Height="36" FontSize="13" CornerRadius="6"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Grid.Column="1" 
                                    Content="← Назад" 
                                    Height="43"
                                    Width="80"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="#6C757D" 
                                    Foreground="White" 
                                    FontSize="13" 
                                    CornerRadius="8" 
                                    x:Name="btn_back" Margin="0,0,0,0"/>

                            <Button Content="Найти" Height="43" Width="70" HorizontalContentAlignment="Center" 
                            VerticalContentAlignment="Center" Background="#0F4B5E" Foreground="White" FontSize="13" CornerRadius="8" Margin="5,0,0,0" x:Name="btn_search"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <TextBlock Grid.Row="2" Margin="24,8,24,8" Text="Результаты поиска:" FontSize="14" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                
                <ScrollViewer Grid.Row="3" Margin="24,0,24,24" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="dealsContainer">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        CornerRadius="12"
                                        BorderBrush="#E9ECEF"
                                        BorderThickness="1"
                                        Padding="16,14"
                                        Margin="0,0,0,12"
                                        Cursor="Hand"
                                        Tapped="OnCardDoubleTapped">
                                    
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel Grid.Column="0" Spacing="8">
                                            <TextBlock Text="{Binding Number}" FontSize="16" FontWeight="SemiBold" Foreground="#0F4B5E"/>
                                            <TextBlock Text="{Binding CitizenFullName}" FontSize="14" Foreground="#1E2A3A"/>
                                            <TextBlock Text="{Binding DateFormatted}" FontSize="12" Foreground="#6C757D"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1"
                                                Content="Выбрать →"
                                                Background="#0F4B5E"
                                                Foreground="White"
                                                CornerRadius="8"
                                                Padding="20,10"
                                                FontSize="13"
                                                Tag="{Binding}"
                                                VerticalAlignment="Center"
                                                Cursor="Hand"
                                                Click="OnSelectClick"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <Border Grid.Row="3"
                        Background="White"
                        IsVisible="False"
                        x:Name="emptyStateBorder">
                    <StackPanel HorizontalAlignment="Center" 
                                VerticalAlignment="Center"
                                Spacing="16">
                        <TextBlock Text="📋" FontSize="64"/>
                        <TextBlock Text="Дела не найдены" FontSize="18" Foreground="#6C757D"/>
                        <TextBlock Text="Измените параметры поиска" FontSize="14" Foreground="#ADB5BD"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>