<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CourseWork.Views.LoginActitvity"
        Title="Вход"
        Width="400" Height="350"
        WindowStartupLocation="CenterScreen">

    <Border Background="#0F4B5E" Padding="40">
        <StackPanel Spacing="15" HorizontalAlignment="Center" 
        VerticalAlignment="Center">
            
            <TextBlock Text="Вход в систему" FontSize="24" 
            FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            
            <TextBox x:Name="txtUsername" 
                     Watermark="Логин" 
                     Background="White" 
                     Height="40"
                     FontSize="14"/>
            
            <TextBox x:Name="txtPassword" 
                     Watermark="Пароль" 
                     Background="White" 
                     Height="40"
                     FontSize="14"
                     PasswordChar= "*"/>
            
            <TextBlock x:Name="txtError" 
                       Text="Ошибка" 
                       Foreground="Red" 
                       IsVisible="False"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
            
            <Button x:Name="btnLogin" 
                    Content="Войти" 
                    Height="40" 
                    Width="120"
                    Background="#1A6B8A" 
                    Foreground="White"
                    CornerRadius="6"
                    FontSize="14"/>
        </StackPanel>
    </Border>
</Window>