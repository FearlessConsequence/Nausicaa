<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:CourseWork.Controls"
        x:Class="CourseWork.Views.MedicalExpertWindow"
        Title="Медицинский эксперт"
        WindowState="Maximized"
        Background="#F5F7FA">

    <Grid RowDefinitions="*, Auto" ColumnDefinitions="200, *">
        
        <controls:LeftPanel x:Name="LeftPanelControl" 
                            Grid.Column="0" 
                            Grid.Row="0" 
                            Grid.RowSpan="2"/>

        <Border Grid.Column="1" Grid.Row="0" Background="White" BorderBrush="#eae9ef" BorderThickness="0, 0, 0, 1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#0F4B5E" Padding="20,10">
                    <TextBlock Text="Роль: Медицинский эксперт" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Row="1" Margin="0, 50" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Создать экспертизу" 
                               FontSize="24" 
                               FontWeight="SemiBold" 
                               Foreground="#0F4B5E"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>
                    
                    <Button Width="250" 
                            Height="80" 
                            Margin="8" 
                            Background="#0F4B5E" 
                            Foreground="White" 
                            BorderThickness="0" 
                            CornerRadius="8"
                            x:Name="btn_create_examination">
                        <StackPanel>
                            <TextBlock Text="🔬" FontSize="30" HorizontalAlignment="Center"/>
                            <TextBlock Text="Судебно-медицинская экспертиза" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <controls:NotificationsControl x:Name="NotificationsControl" 
                                       Grid.Column="0" 
                                       Grid.ColumnSpan="2"
                                       Grid.Row="1"      
                                       VerticalAlignment="Bottom"/>
    </Grid>
</Window>