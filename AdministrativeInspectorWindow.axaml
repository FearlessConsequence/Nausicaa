<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:CourseWork.Controls"
        x:Class="CourseWork.Views.AdminInspectorWindow"
        Title="Инспектор административной практики"
        WindowState="Maximized"
        Background="#F5F7FA">

    <Grid RowDefinitions="*, Auto" ColumnDefinitions="200, *">
        
        <controls:LeftPanel x:Name="LeftPanelControl" 
                            Grid.Column="0" 
                            Grid.Row="0" 
                            Grid.RowSpan="2"/>

        <Border Grid.Column="1" Grid.Row="0" Background="White" BorderBrush="#eae9ef" BorderThickness="0, 0, 0, 1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#0F4B5E" Padding="20,10">
                    <TextBlock Text="Роль: Инспектор административной практики" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Row="1" Margin="0, 30">
                    <TextBlock Text="Быстрое создание документа:" 
                               HorizontalAlignment="Center" 
                               Foreground="#0F4B5E" 
                               FontWeight="SemiBold" 
                               Margin="20, 20" 
                               FontSize="18"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Width="130" x:Name="btn_newAppel" Height="130" Margin="8" Background="#F3F3F3" Foreground="#0F4B5E" BorderThickness="0" CornerRadius="8">
                            <TextBlock Text="Обращение" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Width="130" x:Name="btn_newStatement" Height="130" Margin="8" Background="#F3F3F3" Foreground="#0F4B5E" BorderThickness="0" CornerRadius="8">
                            <TextBlock Text="Заявление" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Width="130" x:Name="btn_newExplanationProtocol" Height="130" Margin="8" Background="#F3F3F3" Foreground="#0F4B5E" BorderThickness="0" CornerRadius="8">
                            <TextBlock Text="Протокол объяснения" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Width="130" x:Name="btn_newExaminationReport" Height="130" Margin="8" Background="#F3F3F3" Foreground="#0F4B5E" BorderThickness="0" CornerRadius="8">
                            <TextBlock Text="Направление на мед. освид." FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button Width="130" x:Name="btn_newAdministrativeProtocol" Height="130" Margin="8" Background="#F3F3F3" Foreground="#0F4B5E" BorderThickness="0" CornerRadius="8">
                            <TextBlock Text="Адм. протокол" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                    </StackPanel>
                    
                    <Border Background="White" 
                            BorderBrush="LightGray" 
                            BorderThickness="1" 
                            BoxShadow="0 0 15 3 #80808080" 
                            CornerRadius="4" 
                            Margin="20,20,20,20" 
                            Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Поиск дел и протоколов" FontWeight="Bold" FontSize="16" Foreground="#0F4B5E"/>
                            <Grid ColumnDefinitions="*, *, *, *, Auto" ColumnSpacing="10">
                                <TextBox Grid.Column="0" Height="32" Watermark="Серия/Номер"/>
                                <TextBox Grid.Column="1" Height="32" Watermark="ФИО / Дата рожд."/>
                                <TextBox Grid.Column="2" Height="32" Watermark="Дело №" x:Name="txbx_deal"/>
                                <TextBox Grid.Column="3" Height="32" Watermark="Телефон"/>
                                <TextBox Grid.Column="4" Height="32" Watermark="Место проживания"/>
                            </Grid>
                            <Button Content="Поиск" Width="80" Height="32" Background="#0F4B5E" Foreground="White" CornerRadius="4" x:Name="btn_searchMain" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        
        <controls:NotificationsControl x:Name="NotificationsControl" 
                                       Grid.Column="0" 
                                       Grid.ColumnSpan="2"
                                       Grid.Row="1"      
                                       VerticalAlignment="Bottom"/>
    </Grid>
</Window>